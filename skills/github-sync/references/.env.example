# Copy this file to references/.env and customize.
# Do not commit real secrets.

# Shared
SYNC_REMOTE="git@github.com:example-org/example-repo.git"
WORKSPACE_DIR="$HOME/.openclaw/workspace"
SYNC_REPO_DIR="$WORKSPACE_DIR/openclaw-sync-repo"

# nightly_sync.sh
REPORT_PATH="$WORKSPACE_DIR/memory/secret-scan-alert.txt"

# pull.sh
PULL_DELETE="0"
PULL_DRY_RUN="0"
OPENCLAW_CONFIG="$HOME/.openclaw/openclaw.json"
